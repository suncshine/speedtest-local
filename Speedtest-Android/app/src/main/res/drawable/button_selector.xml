<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/focusedButtonBackground" />
            <stroke android:width="4dp" android:color="@color/focusedColor" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/startButton_background" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</selector>